// Prisma schema configured for external MySQL.
// Set DATABASE_URL in your .env / hosting environment.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserProfile {
  ADMIN
  FINANCIER
  LOGISTICIEN
  CHEF_CLUB
  AMBASSADEUR
  DESIGNER
  INFORMATICIEN
  AUTEUR
}

enum FinanceEntryType {
  INCOME
  EXPENSE
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  profile      UserProfile @default(AUTEUR)
  clubScopeId  String?
  clubScope    Club?       @relation("UserClubScope", fields: [clubScopeId], references: [id], onDelete: SetNull)
  passwordHash String
  sessions     Session[]
  financeEntriesCreated FinanceEntry[]
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([entityType, entityId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Author {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  bio       String?
  website   String?
  city      String?
  country   String?
  books     Book[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Designer {
  id           String   @id @default(cuid())
  name         String
  email        String?  @unique
  phone        String?
  specialty    String?
  portfolioUrl String?
  country      String?
  bio          String?
  books        Book[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Club {
  id          String        @id @default(cuid())
  name        String
  email       String?       @unique
  phone       String?
  city        String?
  country     String?
  description String?
  foundedAt   DateTime?
  ambassadors Ambassador[]
  members     ClubMember[]
  scopedUsers User[]          @relation("UserClubScope")
  contributions ClubContribution[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Ambassador {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  phone     String?
  city      String?
  country   String?
  bio       String?
  clubId    String?
  club      Club?    @relation(fields: [clubId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
}

model ClubMember {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  city      String?
  status    String?  @map("role")
  joinedAt  DateTime?
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Restrict)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  contributions ClubContribution[]

  @@index([clubId])
}

model ClubContribution {
  id          String     @id @default(cuid())
  clubId      String
  club        Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  memberId    String
  member      ClubMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  monthKey    String
  amountCents Int
  paidAt      DateTime   @default(now())
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([clubId, monthKey])
  @@index([memberId, monthKey])
  @@unique([memberId, monthKey])
}

model FinanceEntry {
  id          String           @id @default(cuid())
  type        FinanceEntryType
  amountCents Int
  category    String
  notes       String?
  occurredAt  DateTime
  createdById String
  createdBy   User             @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([type, occurredAt])
  @@index([createdById])
}

model Book {
  id              String    @id @default(cuid())
  title           String
  isbn            String?   @unique
  description     String?
  publisher       String?   @default("Umoja Editions")
  publishedAt     DateTime?
  language        String?
  pageCount       Int?
  pricePaperCents Int
  priceEbookCents Int
  authorId        String
  author          Author    @relation(fields: [authorId], references: [id], onDelete: Restrict)
  designerId      String?
  designer        Designer? @relation(fields: [designerId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([authorId])
  @@index([designerId])
}
